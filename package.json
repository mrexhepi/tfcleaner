{
  "name": "tfcleaner",
  "version": "1.0.0",
  "description": "Interactive CLI to find and safely clean Terraform/Terragrunt generated files (.terraform, .terragrunt-cache, lock files) and reclaim disk space.",
  "keywords": [
    "terraform",
    "terragrunt",
    "cleanup",
    "cli",
    "disk-space",
    "tui",
    "ink",
    "devops"
  ],
  "license": "MIT",
  "author": "Muharrem Rexhepi",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrexhepi/tfcleaner.git"
  },
  "bugs": {
    "url": "https://github.com/mrexhepi/tfcleaner/issues"
  },
  "homepage": "https://github.com/mrexhepi/tfcleaner#readme",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "tfcleaner": "./bin/tfcleaner.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "main": "dist/cli.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "start": "node bin/tfcleaner.js",
    "prepublishOnly": "npm run build",
    "test": "npm run build && node --test \"test/**/*.test.js\"",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "commander": "12.1.0",
    "fast-glob": "3.3.3",
    "fs-extra": "11.3.5",
    "get-folder-size": "5.0.0",
    "ink": "5.2.1",
    "ora": "8.2.0",
    "react": "18.3.1"
  },
  "devDependencies": {
    "@types/fs-extra": "11.0.4",
    "@types/node": "20.19.43",
    "@types/react": "18.3.31",
    "typescript": "5.9.3"
  }
}
